//        <2=> 2: 010 = HOCO clock
//        <3=> 3: 011 = MOCO clock
//        <4=> 4: 100 = LOCO clock
//        <5=> 5: 101 = Peripheral module clock B (PCLKB)
//        <6=> 6: 110 = IWDT-dedicated clock
//        <7=> 7: Others = Setting prohibited
//    </combo>
//  </item>
//  


