//    <name> STS </name>
//    <rw> 
//    <i> [Bits 10..8] RW (@ 0x400A2710) \nSetting of Start Trigger or Capture Trigger of Channel n\n0 : Others = Setting prohibited\n1 : 001 = Valid edge of the TI0n pin input is used as both the start trigger and capture trigger.\n2 : 010 = Both the edges of the TI0n pin input are used as a start trigger and a capture trigger.\n3 : Reserved - do not use\n4 : 100 = Interrupt signal of the master channel is used (when the channel is used as a slave channel with the simultaneous channel operation function).\n5 : Reserved - do not use\n6 : Reserved - do not use\n7 : Reserved - do not use </i>
//    <combo> 
//      <loc> ( (unsigned short) TAU_TMR00 ) </loc>
//      <o.10..8> STS
//        <0=> 0: 000 = Only software trigger start is valid (other trigger sources are unselected).
//        <1=> 1: 001 = Valid edge of the TI0n pin input is used as both the start trigger and capture trigger.
//        <2=> 2: 010 = Both the edges of the TI0n pin input are used as a start trigger and a capture trigger.
//        <3=> 3: Others = Setting prohibited
//        <4=> 4: 100 = Interrupt signal of the master channel is used (when the channel is used as a slave channel with the simultaneous channel operation function).
//        <5=> 5: Others = Setting prohibited
//        <6=> 6: Others = Setting prohibited
//        <7=> 7: Others = Setting prohibited
//    </combo>
//  </item>
