// SVD Line: 25539

unsigned char RTC_C_RTCC0 __AT (0x400A2C0B);



// -------------------------------  Field Item: RTC_C_RTCC0_CT  -----------------------------------
// SVD Line: 25548

//  <item> SFDITEM_FIELD__RTC_C_RTCC0_CT
//    <name> CT </name>
//    <rw> 
//    <i> [Bits 2..0] RW (@ 0x400A2C0B) \nFixed-cycle interrupt (RTC_ALM_OR_PRD) selection\n0 : Others = Once per 1 month (Day 1, hour 00 a.m., minute 00, and second 00 of every month)\n1 : 001 = Once per 0.5 s (synchronously as the seconds count is updated)\n2 : 010 = Once per 1 s (at the same time as the seconds count is updated)\n3 : 011 = Once per 1 m (second 00 of every minute)\n4 : 100 = Once per 1 hour (minute 00 and second 00 of every hour)\n5 : 101 = Once per 1 day (hour 00, minute 00, and second 00 of every day)\n6 : Reserved - do not use\n7 : Reserved - do not use </i>
//    <combo> 
//      <loc> ( (unsigned char) RTC_C_RTCC0 ) </loc>
//      <o.2..0> CT
//        <0=> 0: 000 = Does not use fixed-cycle interrupt
//        <1=> 1: 001 = Once per 0.5 s (synchronously as the seconds count is updated)
//        <2=> 2: 010 = Once per 1 s (at the same time as the seconds count is updated)
//        <3=> 3: 011 = Once per 1 m (second 00 of every minute)
//        <4=> 4: 100 = Once per 1 hour (minute 00 and second 00 of every hour)
//        <5=> 5: 101 = Once per 1 day (hour 00, minute 00, and second 00 of every day)
//        <6=> 6: Others = Once per 1 month (Day 1, hour 00 a.m., minute 00, and second 00 of every month)
//        <7=> 7: Others = Once per 1 month (Day 1, hour 00 a.m., minute 00, and second 00 of every month)
//    </combo>
//  </item>
//  


