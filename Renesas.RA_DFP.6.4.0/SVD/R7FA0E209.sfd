//        <4=> 4: 100 = One-count mode
//        <5=> 5: Others = Setting prohibited
//        <6=> 6: 110 = Capture and one-count mode
//        <7=> 7: Others = Setting prohibited
//    </combo>
//  </item>
//  


// --------------------------------  Field Item: TAU_TMR00_CIS  -----------------------------------
