//    <combo> 
//      <loc> ( (unsigned short) TAU_TMR00 ) </loc>
//      <o.7..6> CIS
//        <0=> 0: 00 = Falling edge
//        <1=> 1: 01 = Rising edge
//        <2=> 2: 10 = Both edges (when low-level width is measured) Start trigger: Falling edge, Capture trigger: Rising edge
//        <3=> 3: 11 = Both edges (when high-level width is measured) Start trigger: Rising edge, Capture trigger: Falling edge
//    </combo>
//  </item>
//  


// --------------------------------  Field Item: TAU_TMR00_STS  -----------------------------------
